# ══════════════════════════════════════════════════════════════
# Vol Surge Bot v5 — Environment Variable Template
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# On Railway: set these in the Railway dashboard → Variables tab.
# ══════════════════════════════════════════════════════════════

# ── Delta Exchange India API credentials ──────────────────────
# Required for LIVE mode. Not used in PAPER mode.
DELTA_API_KEY_LIVE=
DELTA_API_SECRET_LIVE=

# ── TradingView webhook secret ────────────────────────────────
# Must match the "secret" field in every Pine alert JSON payload.
# Change this from the default before any live deployment.
WEBHOOK_SECRET=change_me_before_live

# ── Telegram notifications ────────────────────────────────────
# Optional. Leave blank to disable Telegram alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Execution mode ────────────────────────────────────────────
# true  = paper mode (no real orders, fills simulated at live price)
# false = live mode (real orders on Delta Exchange India)
# ALWAYS start with true on a new deployment. Validate before switching.
PAPER_MODE=true

# ── Exit authority ────────────────────────────────────────────
# false = monitor-only (recommended)
# true  = hybrid (Pine TP/SL webhooks can also execute exits)
USE_PINE_EXIT_WEBHOOKS=false

# ── Instrument ────────────────────────────────────────────────
# 27 = BTCUSD Perpetual on Delta Exchange India
PRODUCT_ID=27

# ── Position sizing ───────────────────────────────────────────
LOT_SIZE=0.002

# ── Entry quality filter ──────────────────────────────────────
MAX_SLIPPAGE_RATIO=1.0

# ── Minimum sl_dist gate ──────────────────────────────────────
MIN_SL_DIST=100
